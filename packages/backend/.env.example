# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=renovator
DATABASE_USER=renovator
DATABASE_PASSWORD=renovator123

# Keycloak Configuration
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=renovator
KEYCLOAK_CLIENT_ID=renovator-app
KEYCLOAK_CLIENT_SECRET=renovator-client-secret-change-in-production

# Server Configuration
NODE_ENV=development
PORT=4000

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Google Drive Integration (reuse existing Google OAuth client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/google/callback

# Token Encryption (generate with: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=

# Sentry Configuration
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# File Storage Configuration
FILE_STORAGE_BASE_URL=http://localhost:4000/files
FILE_STORAGE_SECRET=change-this-secret-in-production
